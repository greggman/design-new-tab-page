{
  "manifest_version": 3,
  "name": "Design New Tab Page",
  "description": "Design new tab page  ",
  "version": "0.0.0.5",
  "chrome_url_overrides" : {
    "newtab": "newpage.html"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Design New Tab — choose a color"
  },
  "icons": {
    "16":  "/images/icon-16.png",
    "32":  "/images/icon-32.png",
    "48":  "/images/icon-48.png",
    "128": "/images/icon-128.png",
    "512": "/images/icon-512.png"
  }
 }
